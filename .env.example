# Database connection for Cardano DB Sync
DB_URL=postgres://username:password@localhost:5432/cexplorer?sslmode=disable

# Redis configuration (for caching)
REDIS_URL=redis://localhost:6379

# Server configuration
PORT=8080
HOST=0.0.0.0

# API configuration
MAX_PAGE_SIZE=1000
DEFAULT_PAGE_SIZE=1000
CACHE_DURATION_SECONDS=300

# Security configuration
# API_KEYS - Comma-separated list of valid API keys
# Generate keys with: curl http://localhost:8080/generate-key (in development mode)
# Example: API_KEYS=your-secret-key-1,your-secret-key-2,another-key-here
API_KEYS=

# ENVIRONMENT - Set to "development" to enable key generation endpoint
ENVIRONMENT=production